{
  "name": "@testmuai/browser-cloud",
  "version": "1.0.1",
  "description": "Web Browser for AI Agents powered by TestMu AI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:integration:sdk": "jest --config jest.integration.config.js --runInBand --testPathPatterns=sdk-tests",
    "test:integration:cli": "jest --config jest.integration.config.js --runInBand --testPathPatterns=cli-tests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rm -rf dist",
    "dev": "tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LambdaTest/browser-cloud.git"
  },
  "homepage": "https://github.com/LambdaTest/browser-cloud#readme",
  "bugs": {
    "url": "https://github.com/LambdaTest/browser-cloud/issues"
  },
  "keywords": [
    "puppeteer",
    "playwright",
    "selenium",
    "lambdatest",
    "ai-agent",
    "browser-automation",
    "stealth",
    "headless",
    "web-scraping",
    "testing",
    "cloud-browser"
  ],
  "author": "TestMu AI <support@testmuai.com>",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "testmu-browser-cloud": "./dist/cli/index.js",
    "testmu-browser-cloud-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist",
    "skills",
    "hooks",
    "scripts",
    ".claude-plugin",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@lambdatest/node-tunnel": "^4.0.10",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chrome-launcher": "^1.2.1",
    "commander": "^14.0.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.3",
    "playwright-core": ">=1.40.0",
    "puppeteer-core": ">=20.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "selenium-webdriver": ">=4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/selenium-webdriver": "^4.35.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "playwright-core": ">=1.40.0",
    "puppeteer-core": ">=20.0.0",
    "selenium-webdriver": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer-core": {
      "optional": true
    },
    "playwright-core": {
      "optional": true
    },
    "selenium-webdriver": {
      "optional": true
    }
  }
}
